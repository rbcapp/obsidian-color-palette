{
  "compilerOptions": {
    // "baseUrl": "src", TODO: REGRESSION TEST THIS CHANGE FOR TYPESCRIPT 7.0
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "nodenext",
    "target": "ES2018",
    "allowJs": true, //change to false
    "noImplicitAny": true,
    "moduleResolution": "nodenext",
